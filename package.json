{
  "name": "@oreo-ui/avatar",
  "version": "0.1.0",
  "description": "Figma-method soft gradient avatar generator with shape presets, palette presets, light/dark appearances, and OKLCH tone controls.",
  "type": "module",
  "license": "MIT",
  "author": "BIAsia",
  "homepage": "https://github.com/BIAsia/oreo-ui-avatar#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BIAsia/oreo-ui-avatar.git"
  },
  "bugs": {
    "url": "https://github.com/BIAsia/oreo-ui-avatar/issues"
  },
  "keywords": [
    "avatar",
    "avatar-generator",
    "svg",
    "gradient",
    "oklch",
    "identicon",
    "profile-picture",
    "react",
    "dark-mode",
    "figma",
    "oreo-ui"
  ],
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react.d.ts",
        "default": "./dist/react.js"
      },
      "require": {
        "types": "./dist/react.d.cts",
        "default": "./dist/react.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "oreo-avatar": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "vite --host 0.0.0.0",
    "smoke": "node -e \"const m=require('./dist/index.cjs');if(typeof m.createAvatar!=='function')throw new Error('cjs entry broken')\" && node --input-type=module -e \"import('./dist/index.js').then(m=>{if(typeof m.createAvatar!=='function')throw new Error('esm entry broken')})\" && node dist/cli.js help > /dev/null",
    "preview:assets": "node scripts/generate-preview.mjs",
    "verify": "npm run typecheck && npm run test && npm run build && npm run smoke",
    "prepublishOnly": "npm run verify"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.0.3",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^5.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  }
}
